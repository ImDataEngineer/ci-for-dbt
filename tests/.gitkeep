# Pose tes tests singuliers ici (un fichier .sql par test).
# Un test singulier est une requête qui retourne des lignes quand une règle
# métier est violée. Exemple : "une commande doit avoir un montant > 0,
# sauf si elle est cancelled ou refunded" :
#
#   select *
#   from {{ ref('fct_orders') }}
#   where amount_cents <= 0
#     and status not in ('cancelled', 'refunded')
#
# Le test passe quand la requête retourne zéro ligne.
